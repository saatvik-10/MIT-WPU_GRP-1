model QuizAttempt {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleUrl String
  quizTitle  String
  quizType   QuizType

  score              Int
  totalQuestions     Int
  accuracyPercentage Float

  xpEarned Int @default(0)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([articleUrl])
  @@index([createdAt])
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCE
}

enum Gender {
  MALE
  FEMALE
  OTHERS
}

enum Type {
  DOMAIN
  PREFERENCE
}

enum BookmarkSource {
  ARTICLE
  THREADS
}

enum Role {
  USER
  ASSISTANT
}

enum QuizType {
  JARGON
  SUMMARY
}
